<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/p2"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingBottom="8dp">

    <!-- 节点指示器（顶部，含阶段名称） -->
    <LinearLayout
        android:id="@+id/layout_progress_nodes"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 右上角生命值 -->
    <LinearLayout
        android:id="@+id/layout_heart_container"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_progress_nodes">

        <TextView
            android:id="@+id/tv_heart_1"
            android:layout_width="20dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="♥"
            android:textColor="#E53935"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_heart_2"
            android:layout_width="20dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="♥"
            android:textColor="#E53935"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_heart_3"
            android:layout_width="20dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="♥"
            android:textColor="#E53935"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 叙事文本（旁白） -->
    <TextView
        android:id="@+id/tv_narration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_narration_rounded"
        android:gravity="start|center_vertical"
        android:lineSpacingExtra="1dp"
        android:padding="5dp"
        android:textColor="#4A3C2A"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@id/layout_heart_container"
        app:layout_constraintEnd_toStartOf="@id/layout_heart_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/layout_heart_container" />

    <!-- ========== 阶段提示 ========== -->

    <LinearLayout
        android:id="@+id/layout_hint_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/layout_play_zone_left"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_narration"
        app:layout_constraintVertical_bias="1.0">

        <TextView
            android:id="@+id/tv_stage_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#F6F2E8"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_ai_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#8B7355"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ========== 左侧 AI 阵营（1~3 个，垂直均匀分布） ========== -->
    <LinearLayout
        android:id="@+id/layout_ai_seats"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginStart="2dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/layout_play_zone_left"
        app:layout_constraintEnd_toStartOf="@id/layout_play_zone_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/layout_play_zone_left">

        <LinearLayout
            android:id="@+id/opponent_top"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E8D5A3"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/avatar_top"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_avatar_border"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/t1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/opponent_left"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E8D5A3"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/avatar_left"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_avatar_border"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/t2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/opponent_right"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E8D5A3"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/avatar_right"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_avatar_border"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/t3" />
        </LinearLayout>
    </LinearLayout>

    <!-- ========== 中间双框出牌展示区 ========== -->

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <LinearLayout
        android:id="@+id/layout_play_zone_left"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_play_zone"
        android:gravity="center"
        android:minHeight="80dp"
        android:orientation="vertical"
        android:padding="5dp"
        app:layout_constraintEnd_toStartOf="@id/guideline_center"
        app:layout_constraintStart_toEndOf="@id/layout_ai_seats"
        app:layout_constraintTop_toBottomOf="@id/layout_hint_progress">

        <TextView
            android:id="@+id/tv_last_round_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:text="上一轮出牌："
            android:textColor="#F6F2E8"
            android:textSize="10sp" />

        <LinearLayout
            android:id="@+id/layout_last_round_cards"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_play_zone_right"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_play_zone"
        android:gravity="center"
        android:minHeight="80dp"
        android:orientation="vertical"
        android:padding="5dp"
        app:layout_constraintEnd_toStartOf="@id/layout_user_faction"
        app:layout_constraintStart_toEndOf="@id/guideline_center"
        app:layout_constraintTop_toBottomOf="@id/layout_hint_progress">

        <TextView
            android:id="@+id/tv_play_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:text="请根据阶段提示选择手牌："
            android:textColor="#F6F2E8"
            android:textSize="10sp" />

        <LinearLayout
            android:id="@+id/layout_player_played_cards"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:minHeight="36dp"
            android:orientation="horizontal" />
    </LinearLayout>

    <!-- ========== 用户阵营（右侧，对齐出牌框中间高度） ========== -->
    <LinearLayout
        android:id="@+id/layout_user_faction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="2dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/layout_play_zone_right"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/layout_play_zone_right"
        app:layout_constraintTop_toTopOf="@id/layout_play_zone_right">

        <TextView
            android:id="@+id/tv_user_faction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E8D5A3"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/avatar_user"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_avatar_border"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/t4" />
    </LinearLayout>

    <!-- ========== 底部 ========== -->

    <Button
        android:id="@+id/btn_submit_event_cards"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_button_red"
        android:text="出牌"
        android:textColor="#F6F2E8"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_abandon_narrative"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_button_rounded"
        android:text="放弃"
        android:textColor="#E8D5A3"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <HorizontalScrollView
        android:id="@+id/layout_hand_cards"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="2dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_abandon_narrative"
        app:layout_constraintStart_toEndOf="@id/btn_submit_event_cards">

        <FrameLayout
            android:id="@+id/layout_hand_cards_wrapper"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/layout_hand_cards_inner"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </FrameLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>